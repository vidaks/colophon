# Colophon configuration — copy to .env and fill in, or export these.
# Secrets stay in the environment; they are never written into the repo or logs.

# --- Server (Booklore-family; developed against grimmory/Edda) ---
GRIMMORY_URL=http://localhost:6060/api/v1
COLOPHON_ADMIN_USER=admin
COLOPHON_ADMIN_GROUP=admin
# Read-only DB snapshot is taken via `podman exec <container> mariadb ... <db>`:
COLOPHON_DB_CONTAINER=grimmory-db
COLOPHON_DB_NAME=grimmory

# --- Metadata provider (Hardcover) ---
COLOPHON_HARDCOVER_KEY=
# ...or, to keep the key out of this process, a command that takes GraphQL on stdin
# and returns the JSON response (e.g. a secrets-manager wrapper):
# COLOPHON_HARDCOVER_QUERY_CMD=/path/to/hardcover-query.sh

# --- LLM adjudicator (for `resolve`) ---
# Set the API key to call Anthropic directly; leave unset to use the `claude` CLI.
ANTHROPIC_API_KEY=

# --- State (defaults are repo-relative; set absolute paths for a service) ---
# COLOPHON_DB=/var/lib/colophon/colophon.db
# COLOPHON_REPORTS=/var/lib/colophon/reports

# --- Weekly oversight email (sent ONLY on DRIFT/REVIEW) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
OVERSIGHT_TO=
